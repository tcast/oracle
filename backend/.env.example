# API Keys
NEWS_API_KEY=your_news_api_key
FINNHUB_API_KEY=your_finnhub_api_key
ALPHA_VANTAGE_API_KEY=your_alphavantage_api_key
POLYGON_API_KEY=your_polygon_api_key
CRYPTO_COMPARE_API_KEY=your_cryptocompare_api_key

# Email Account Creation Services
FIVESIM_API_KEY=your_5sim_api_key
TWOCAPTCHA_API_KEY=your_2captcha_api_key
CAPSOLVER_API_KEY=your_capsolver_api_key

# App URLs (OAuth redirects — shared infrastructure)
APP_BASE_URL=http://localhost:3021
BACKEND_URL=http://localhost:3021
FRONTEND_URL=http://localhost:3020

# Optional global OAuth fallbacks (prefer per-brand credentials in DB via Brands UI)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# META_APP_ID=
# META_APP_SECRET=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Ad creative image model (gpt-image-1 default)
OPENAI_IMAGE_MODEL=gpt-image-1

# ProxyBase (sticky residential/mobile HTTP proxies)
# Put generated session URLs in backend/private/proxybase-proxies.txt (gitignored)
# then: node src/scripts/import-proxybase-proxies.js private/proxybase-proxies.txt --auto-assign --replace
PROXYBASE_USERNAME=
PROXYBASE_PASSWORD=
PROXYBASE_HOST=proxy.proxybase.org
PROXYBASE_PORT=1081
REQUIRE_PROXY_FOR_LIVE=true

# BullMQ durable schedulers (organic comments + nightly account stats)
REDIS_HOST=redis
REDIS_PORT=6379
