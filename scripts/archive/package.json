{
  "name": "oracle",
  "version": "1.0.0",
  "description": "Oracle is a comprehensive platform for managing social media campaigns, generating content, and analyzing investment opportunities.",
  "main": "backend/src/app.js",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "dev:backend": "nodemon backend/src/app.js",
    "dev:frontend": "cd frontend && vite",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npm install && npx vite build",
    "preview": "vite preview",
    "create-user": "node backend/scripts/createUser.js",
    "start": "node backend/src/app.js",
    "heroku-postbuild": "npm install && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.758.0",
    "@aws-sdk/client-lambda": "^3.758.0",
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/client-sns": "^3.758.0",
    "@aws-sdk/client-timestream-query": "^3.758.0",
    "@aws-sdk/client-timestream-write": "^3.758.0",
    "archiver": "^7.0.1",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.8.3",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.0.0",
    "chromedriver": "^133.0.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "fs-extra": "^11.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.0.0",
    "pg": "^8.14.0",
    "pg-pool": "^3.6.1",
    "pg-types": "^4.0.1",
    "rxjs": "^7.8.1",
    "selenium-webdriver": "^4.28.1"
  },
